KLO_MODE=local

# Bring your own model key. Set one provider as the default.
MODEL_PROVIDER=openai
OPENAI_API_KEY=replace-with-your-openai-key
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=replace-with-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-5

MAX_TURNS=30
MAX_TOOL_CALLS=80
MAX_SCREENSHOTS=12
MAX_WALL_TIME_SECONDS=300

CONTROLLED_BROWSER_PORT=9333
CONTROLLED_BROWSER_PROFILE=.klo/controlled-browser
DATABASE_PATH=klo.sqlite3
ARTIFACTS_DIR=.klo/runs

USE_DEDICATED_SPACE=false
DEDICATED_SPACE_KEY=ctrl+right
PAUSE_ON_CONTROLLER_FOCUS=true
CONTROLLER_APP_NAMES=Cursor,Wispr Flow

HOST=127.0.0.1
PORT=8765

# Optional: point at hosted KLO if you are developing official hosted features.
KLO_CLOUD_URL=
